class Oasis < Formula
  desc "OpenAPI 3.0/3.1 toolkit: linter, multi-file bundler, and LSP server"
  homepage "https://github.com/Lazialize/oasis"
  version "{{VERSION}}"
  license "MIT"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/Lazialize/oasis/releases/download/v{{VERSION}}/oasis-darwin-arm64.tar.gz"
      sha256 "{{SHA256_DARWIN_ARM64}}"
    else
      url "https://github.com/Lazialize/oasis/releases/download/v{{VERSION}}/oasis-darwin-x64.tar.gz"
      sha256 "{{SHA256_DARWIN_X64}}"
    end
  end

  on_linux do
    if Hardware::CPU.arm?
      url "https://github.com/Lazialize/oasis/releases/download/v{{VERSION}}/oasis-linux-arm64.tar.gz"
      sha256 "{{SHA256_LINUX_ARM64}}"
    else
      url "https://github.com/Lazialize/oasis/releases/download/v{{VERSION}}/oasis-linux-x64.tar.gz"
      sha256 "{{SHA256_LINUX_X64}}"
    end
  end

  def install
    binary = Dir["oasis-*"].first
    bin.install binary => "oasis"
  end

  test do
    system "#{bin}/oasis", "--help"
  end
end
