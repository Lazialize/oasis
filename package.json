{
  "name": "oasis",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "test:bin": "bun test packages/cli/tests/binary.test.ts",
    "typecheck": "bunx tsc --noEmit",
    "oasis": "bun run packages/cli/src/index.ts",
    "build:bin": "bun build packages/cli/src/index.ts --compile --minify --outfile dist/oasis",
    "changeset": "changeset",
    "version": "changeset version && bun run scripts/sync-extension-version.ts"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "bun-types": "^1.3.14",
    "typescript": "^5.7.2"
  }
}
